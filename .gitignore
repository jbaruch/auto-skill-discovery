# Per-run discovery / eval artifacts at the project root — large, regenerable, not source-of-truth.
# Root-anchored so eval-scenario fixtures under evals/<name>/runs/ stay tracked and ship in the published tile.
/runs/

# Build / cache
__pycache__/
*.pyc
.pytest_cache/
.DS_Store

# Editor
.vscode/
.idea/

# Local Tessl state (consumer side — content comes from tessl install at runtime)
.tessl/tiles/
